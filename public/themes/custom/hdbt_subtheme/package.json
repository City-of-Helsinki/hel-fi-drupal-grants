{
  "name": "hdbt_subtheme",
  "version": "1.2.0",
  "description": "Theme builder configuration for HDBT subtheme",
  "author": "Druid",
  "license": "MIT",
  "repository": "github:City-of-Helsinki/hel-fi-drupal-grants",
  "scripts": {
    "dev": "node theme-builder.mjs --watch --dev",
    "build": "npm run format:js --loglevel=silent && npm run lint --loglevel=silent && node theme-builder.mjs",
    "preinstall": "npx update-browserslist-db@latest --loglevel=silent",
    "postinstall": "npm --prefix ../../contrib/hdbt install --no-audit --progress=false --loglevel=silent",
    "lint:scss": "npx --prefix ../../contrib/hdbt/theme-builder postcss \"$INIT_CWD/src/scss/**/*.scss\" --syntax postcss-scss --use css-declaration-sorter --replace --no-map && npm run lint:stylelint --loglevel=silent",
    "lint:stylelint": "npx --prefix ../../contrib/hdbt/theme-builder stylelint \"$INIT_CWD/src/scss/**/*.scss\" --config ../../contrib/hdbt/theme-builder/.stylelintrc.yaml --fix",
    "lint:js": "biome lint src/js/",
    "format:js": "biome format --write src/js/",
    "lint": "npm-run-all --parallel lint:scss lint:js -s",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "validate-ts": "npx --prefix ../../contrib/hdbt tsc --noEmit 2>&1 | grep -v 'hdbt' || true"
  },
  "@comment dependencies": [
    "The following packages were updated manually.",
    "Remove this section once the dependencies have been updated in their respective upstream packages.",
    {
      "brace-expansion": ">=5.0.5, dependency of minimatch",
      "minimatch": ">=10.2.1, dependency of hds-core (eslint)"
    }
  ],
  "overrides": {
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.2.1"
  },
  "dependencies": {
    "@biomejs/biome": "^2.2.4",
    "@hdbt/theme-builder": "file:../../contrib/hdbt/theme-builder",
    "@rjsf/core": "^5.24.3",
    "@rjsf/utils": "^5.24.3",
    "@rjsf/validator-ajv8": "^5.24.3",
    "@sentry/react": "^9.1.0",
    "ajv": "^8.17.1",
    "breakpoint-sass": "^3.0.0",
    "glob": "^11.0.0",
    "i18next": "^25.1.2",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^8.0.4",
    "react-i18next": "^15.5.1",
    "vitest": "^3.0.8"
  },
  "browserslist": [
    "last 3 major versions",
    "> 1%",
    "not dead"
  ],
  "devDependencies": {
    "@testing-library/react": "^12.1.5",
    "@types/json-schema": "^7.0.15",
    "@types/react-router-dom": "^5.1.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.8",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.1.0",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^12.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^2.8.0",
    "stylelint-high-performance-animation": "^1.10.0",
    "stylelint-order": "^6.0.0",
    "stylelint-scss": "^6.0.0",
    "vitest": "^3.0.8"
  }
}
