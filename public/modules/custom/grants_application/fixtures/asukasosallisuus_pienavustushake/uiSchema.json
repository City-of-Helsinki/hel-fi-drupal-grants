{
  "grant_info_step": {
    "subventions_section": {
      "subventions": {
        "ui:field": "subventionTable"
      }
    },
    "purpose_section": {
      "purpose_intro_text": {
        "ui:field": "textParagraph"
      },
      "purpose": {
        "ui:widget": "textarea",
        "misc:max-length": 5000,
        "ui:options": {
          "tooltipLabel": "purpose.title",
          "tooltipButtonLabel": "purpose.title",
          "tooltipText": "purpose.description"
        }
      }
    },
    "other_compensations_section": {
      "have_received_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_compensations": {
        "ui:options": {
          "addText": "other_compensation.add"
        },
        "items": {
          "other_compensation_issuer_name": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_compensation_amount": {
            "ui:options": {
              "printableName": "other_compensation_amount.printable_title"
            }
          },
          "other_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    },
    "other_applied_compensations_section": {
      "have_applied_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_applied_compensations": {
        "ui:options": {
          "addText": "other_applied_compensations.add"
        },
        "items": {
          "other_applied_compensation_issuer_name": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_applied_compensation_amount": {
            "ui:options": {
              "printableName": "other_applied_compensation_amount.printable_title"
            }
          },
          "other_applied_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    },
    "city_benefits_loans_section": {
      "city_benefits_loans": {
        "ui:widget": "textarea"
      }
    },
    "city_premises_benefits_section": {
      "city_premises_benefits": {
        "ui:widget": "textarea"
      }
    }
  },
  "community_activity_step": {
    "community_activity_section": {
      "community_activity_description": {
        "misc:profilePrefill": "businessPurpose",
        "ui:widget": "textarea",
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "community_activity.title",
          "tooltipButtonLabel": "community_activity.title",
          "tooltipText": "community_activity.description"
        }
      },
      "community_practices_business": {
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:widget": "radio"
      }
    },
    "community_fees_section": {
      "fee_person": {},
      "fee_community": {}
    },
    "community_members_section": {
      "members_fieldset": {
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "members_fieldset.legend",
          "tooltipButtonLabel": "cmembers_fieldset.legend",
          "tooltipText": "members_fieldset.description"
        },
        "members_applicant_person_global": {
          "ui:options": {
            "tooltipLabel": "members_applicant_person_global.title",
            "tooltipButtonLabel": "members_applicant_person_global.title",
            "tooltipText": "members_applicant_person_global.description"
          }
        },
        "members_applicant_person_local": {
          "ui:options": {
            "tooltipLabel": "members_applicant_person_local.title",
            "tooltipButtonLabel": "members_applicant_person_local.title",
            "tooltipText": "members_applicant_person_local.description"
          }
        },
        "members_applicant_community_global": {
          "ui:options": {
            "tooltipLabel": "members_applicant_community_global.title",
            "tooltipButtonLabel": "members_applicant_community_global.title",
            "tooltipText": "members_applicant_community_global.description"
          }
        },
        "members_applicant_community_local": {
          "ui:options": {
            "tooltipLabel": "members_applicant_community_local.title",
            "tooltipButtonLabel": "members_applicant_community_local.title",
            "tooltipText": "members_applicant_community_local.description"
          }
        }
      },
      "ui:options": {
        "hideNameFromPrint": true
      }
    }
  },
  "attachments_step": {
    "additional_information_section": {
      "additional_information": {
        "ui:widget": "textarea",
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "additional_information.title",
          "tooltipButtonLabel": "additional_information.title",
          "tooltipText": "additional_information.description"
        }
      }
    },
    "attachments_section": {
      "cant_view_after_help": {
        "misc:variant": "infobox",
        "ui:field": "textParagraph"
      },
      "further_clarification": {
        "ui:widget": "textarea"
      },
      "other_attachment_fieldset": {
        "other_attachment_fieldset_file": {
          "misc:file-type": 0,
          "misc:variant": "simple",
          "ui:help": "other_attachment_fieldset.ui_help",
          "ui:field": "atvFile"
        }
      }
    }
  }
}
