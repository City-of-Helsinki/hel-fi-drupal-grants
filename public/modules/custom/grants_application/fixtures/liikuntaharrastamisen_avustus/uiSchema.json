{
  "grant_info_step": {
    "subventions_section": {
      "grants_compensations_info": {
        "ui:field": "textParagraph"
      },
      "subventions": {
        "ui:field": "subventionTable"
      }
    },
    "purpose_section": {
      "purpose": {
        "ui:widget": "textarea",
        "misc:max-length": 1250,
        "ui:options": {
          "tooltipLabel": "custom_purpose.title",
          "tooltipButtonLabel": "custom_purpose.title",
          "tooltipText": "custom_purpose.description"
        }
      }
    },
    "other_compensations_section": {
      "have_received_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_compensations": {
        "ui:options": {
          "addText": "other_compensation.add"
        },
        "items": {
          "other_compensation_issuer": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_compensation_amount": {
            "ui:options": {
              "printableName": "other_compensation_amount.printable_title"
            }
          },
          "other_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    },
    "other_applied_compensations_section": {
      "have_applied_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_applied_compensations": {
        "ui:options": {
          "addText": "other_applied_compensations.add"
        },
        "items": {
          "other_applied_compensation_issuer": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_applied_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    }
  },
