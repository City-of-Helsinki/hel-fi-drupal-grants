  "attachments_step": {
    "additional_information_section": {
      "additional_information": {
        "ui:widget": "textarea",
        "misc:max-length": 5000,
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "additional_information.title",
          "tooltipButtonLabel": "additional_information.title",
          "tooltipText": "additional_information.description"
        }
      }
    },
    "attachments_section": {
      "required_attachments_help": {
        "ui:field": "textParagraph"
      },
      "multiple_attachments_help": {
        "ui:field": "textParagraph"
      },
      "cant_view_after_help": {
        "misc:variant": "infobox",
        "ui:field": "textParagraph"
      },
      "project_plan_fieldset": {
        "ui:options": {
          "tooltipLabel": "project_plan_attachment.title",
          "tooltipButtonLabel": "project_plan_attachment.title",
          "tooltipText": "project_plan_attachment.description"
        },
        "project_plan_fieldset_file": {
          "misc:file-type": 19,
          "misc:required": true,
          "ui:field": "atvFile",
          "ui:help": "other_attachment_fieldset.ui_help"
