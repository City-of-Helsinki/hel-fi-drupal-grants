    "contents_section": {
      "artistic_starting_points": {
        "ui:widget": "textarea",
        "misc:max-length": 1000,
        "ui:options": {
          "tooltipLabel": "artistic_starting_points.title",
          "tooltipButtonLabel": "artistic_starting_points.title",
          "tooltipText": "artistic_starting_points.description"
        }
      },
      "diversity_and_equality": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      }
