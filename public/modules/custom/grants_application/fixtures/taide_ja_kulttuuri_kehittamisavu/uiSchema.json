          "ui:field": "atvFile",
          "ui:help": "other_attachment_fieldset.ui_help"
        }
      },
      "further_clarification": {
        "ui:widget": "textarea",
        "misc:max-length": 5000
      },
      "other_attachment_fieldset": {
        "other_attachment_fieldset_file": {
          "misc:file-type": 0,
          "misc:multiple": "true",
          "misc:variant": "simple",
          "ui:field": "atvFile",
          "ui:help": "other_attachment_fieldset_multiple_files.ui_help"
        }
      }
    }
