{
  "grant_info_step": {
    "acting_year_section": {
      "acting_year": {
        "ui:field": "actingYear"
      }
    },
    "subventions_section": {
      "subventions": {
        "ui:field": "subventionTable",
        "ui:options": {
          "useSingleSubvention": true
        }
      }
    },
    "multi_year_section": {
      "is_multi_year_grant": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "affirmativeExpands": true
        }
      },
      "multi_year_grant_years": {
        "misc:max-length": 100,
        "ui:options": {
          "tooltipLabel": "multi_year_grant_years.title",
          "tooltipButtonLabel": "multi_year_grant_years.title",
          "tooltipText": "multi_year_grant_years.description"
        }
      },
      "multi_year_grant_breakdown": {
        "misc:max-length": 100,
        "ui:options": {
          "tooltipLabel": "multi_year_grant_breakdown.title",
          "tooltipButtonLabel": "multi_year_grant_breakdown.title",
          "tooltipText": "multi_year_grant_breakdown.description"
        }
      }
    },
    "primary_art_section": {
      "primary_art": {
        "ui:widget": "select",
        "ui:options": {
          "tooltipLabel": "primary_art.title",
          "tooltipButtonLabel": "primary_art.title",
          "tooltipText": "primary_art.description"
        }
      }
    },
    "project_info_section": {
      "ui:order": [
        "project_name",
        "is_festival_or_event",
        "project_short_description"
      ],
      "project_name": {
        "misc:max-length": 100,
        "ui:options": {
          "tooltipLabel": "project_name.title",
          "tooltipButtonLabel": "project_name.title",
          "tooltipText": "project_name.description"
        }
      },
      "is_festival_or_event": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "tooltipLabel": "is_festival_or_event.title",
          "tooltipButtonLabel": "is_festival_or_event.title",
          "tooltipText": "is_festival_or_event.tooltip"
        }
      },
      "project_short_description": {
        "ui:widget": "textarea",
        "misc:max-length": 700,
        "ui:options": {
          "tooltipLabel": "project_short_description.title",
          "tooltipButtonLabel": "project_short_description.title",
          "tooltipText": "project_short_description.description"
        }
      }
    },
    "received_compensations_section": {
      "have_received_other_compensations": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "affirmativeExpands": true
        }
      },
      "received_compensations": {
        "ui:options": {
          "addText": "other_compensation.add"
        },
        "items": {
          "received_compensation_issuer_name": {
            "ui:options": {
              "tooltipLabel": "received_compensation_issuer_name.title",
              "tooltipButtonLabel": "received_compensation_issuer_name.title",
              "tooltipText": "received_compensation_issuer_name.description"
            }
          },
          "received_compensation_amount": {
            "ui:options": {
              "printableName": "received_compensation_amount.printable_title"
            }
          },
          "received_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "received_compensation_description.title",
              "tooltipButtonLabel": "received_compensation_description.title",
              "tooltipText": "received_compensation_description.description"
            }
          }
        }
      }
    }
  },
  "community_info_step": {
    "members_section": {
      "members_fieldset": {
        "ui:options": {
          "tooltipLabel": "members_count_fieldset.legend",
