    "accessibility_section": {
      "accessibility": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      },
      "community_spirit": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      },
      "target_audiences": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      }
    },
    "operations_section": {
      "professionalism": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      },
      "ecology": {
        "ui:widget": "textarea",
        "misc:max-length": 1000
      },
      "partners": {
        "ui:widget": "textarea",
        "misc:max-length": 1000,
        "ui:options": {
          "tooltipLabel": "partners.title",
          "tooltipButtonLabel": "partners.title",
          "tooltipText": "partners.description"
        }
      }
    }
  },
  "budget_step": {
    "budget_info_section": {
      "budget_info": {
        "ui:field": "textParagraph"
      },
      "belongs_to_vos": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "tooltipLabel": "belongs_to_vos.title",
          "tooltipButtonLabel": "belongs_to_vos.title",
          "tooltipText": "belongs_to_vos.tooltip"
        }
      }
    },
    "income_section": {
      "incomeGroupName": {
        "ui:widget": "hidden"
      },
      "compensation": {
        "ui:field": "computedSum",
        "ui:options": {
          "sourceFields": ["grant_info_step.subventions_section.subventions"],
