        }
      },
      "planned_other_compensations": {
        "ui:options": {
          "tooltipLabel": "planned_other_compensations.title",
          "tooltipButtonLabel": "planned_other_compensations.title",
          "tooltipText": "planned_other_compensations.tooltip"
        }
      },
      "entry_fees": {
        "ui:options": {
          "tooltipLabel": "entry_fees.title",
          "tooltipButtonLabel": "entry_fees.title",
          "tooltipText": "entry_fees.tooltip"
        }
      }
