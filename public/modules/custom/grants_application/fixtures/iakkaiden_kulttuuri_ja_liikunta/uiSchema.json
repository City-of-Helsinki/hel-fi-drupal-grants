        "ui:widget": "textarea",
        "misc:max-length": 300
      },
      "project_purpose_goals": {
        "ui:widget": "textarea",
        "misc:max-length": 2500
      },
      "is_application_extension": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        }
      },
      "actions_and_timeline": {
        "actions_timeline_info": {
