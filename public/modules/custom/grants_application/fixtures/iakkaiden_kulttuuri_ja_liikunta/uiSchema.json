        },
        "grant_goals_3": {
          "ui:widget": "textarea",
          "misc:max-length": 1250
        },
        "grant_goals_4": {
          "ui:widget": "textarea",
          "misc:max-length": 1250
        },
        "grant_goals_5": {
          "ui:widget": "textarea",
          "misc:max-length": 1250
        },
        "grant_goals_6": {
          "ui:widget": "textarea",
          "misc:max-length": 1250
        }
      }
    },
    "target_groups_section": {
      "target_groups_for_who": {
        "ui:widget": "textarea",
        "misc:max-length": 1250
      },
      "target_groups_participation": {
        "ui:widget": "textarea",
        "misc:max-length": 1250
      },
      "target_groups_skills": {
        "ui:widget": "textarea",
        "misc:max-length": 1250
      },
      "assesment_1_fieldset": {
        "ui:options": {
          "hideNameFromPrint": true
        },
        "target_groups_reached_in_helsinki": {
          "ui:options": {
            "tooltipLabel": "target_groups_reached_in_helsinki.title",
            "tooltipButtonLabel": "target_groups_reached_in_helsinki.title",
            "tooltipText": "target_groups_reached_in_helsinki.description"
          }
        },
        "event_count_total": {
          "ui:options": {
            "tooltipLabel": "event_count_total.title",
            "tooltipButtonLabel": "event_count_total.title",
            "tooltipText": "event_count_total.description"
          }
        }
      },
      "assesment_2_fieldset": {
        "ui:options": {
