{
  "grant_info_step": {
    "acting_year_section": {
      "acting_year": {
        "ui:field": "actingYear"
      }
    },
    "subventions_section": {
      "subventions": {
        "ui:field": "subventionTable"
      }
    },
    "purpose_section": {
      "purpose": {
        "ui:widget": "textarea",
        "misc:max-length": 1250,
        "ui:options": {
          "tooltipLabel": "purpose_section_purpose.title",
          "tooltipButtonLabel": "purpose_section_purpose.title",
          "tooltipText": "purpose.description"
        }
      }
    },
    "other_compensations_section": {
      "have_received_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_compensations": {
        "ui:options": {
          "addText": "other_compensation.add"
        },
        "items": {
          "other_compensation_issuer": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_compensation_amount": {
            "ui:options": {
              "printableName": "other_compensation_amount.printable_title"
            }
          },
          "other_compensation_description": {
            "ui:widget": "textarea",
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    },
    "other_applied_compensations_section": {
      "have_applied_other_compensations": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        },
        "ui:widget": "radio"
      },
      "other_applied_compensations": {
        "ui:options": {
          "addText": "other_applied_compensations.add"
        },
        "items": {
          "other_applied_compensation_issuer": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_applied_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    }
  },
  "information_in_more_detail_step": {
    "information_in_more_detail_section": {
      "project_plan_grant_duration": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "project_plan_grant_duration.opt1",
          "project_plan_grant_duration.opt2",
          "project_plan_grant_duration.opt3"
        ]
      },
      "applied_grant_amount": {
        "ui:options": {
          "hideNameFromPrint": true
        },
        "applied_grant_amount_2026": {
          "ui:options": {
            "printableName": "applied_grant_amount_2026.title"
          }
        },
        "applied_grant_amount_2027": {
          "ui:options": {
            "printableName": "applied_grant_amount_2027.title"
          }
        },
        "applied_grant_amount_2028": {
          "ui:options": {
            "printableName": "applied_grant_amount_2028.title"
          }
        }
      },
      "applied_grant_amount_help": {
        "ui:field": "textParagraph"
      }
    },
    "project_plan_section": {
      "ui:order": [
        "project_name",
        "project_purpose_goals",
        "is_application_extension",
        "actions_and_timeline",
        "grant_interim_report_2025",
        "grant_goals_fieldset"
