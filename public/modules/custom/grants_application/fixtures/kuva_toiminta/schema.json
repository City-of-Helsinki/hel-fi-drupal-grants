{
  "definitions": {
    "_other_compensation_item": {
      "type": "object",
      "properties": {
        "other_compensation_issuer": {
          "title": "other_compensation_issuer.title",
          "type": "string",
          "enum": [
            "other_compensation_issuer.state",
            "other_compensation_issuer.eu",
            "other_compensation_issuer.other",
            "other_compensation_issuer.insitute"
          ]
        },
        "other_compensation_issuer_name": {
          "title": "other_compensation_issuer_name.title",
          "type": "string"
        },
        "other_compensation_issuer_year": {
          "title": "other_compensation_issuer_year.title",
          "type": "string"
        },
        "other_compensation_amount": {
          "format": "decimal-number",
          "title": "other_compensation_amount.title",
          "type": "string"
        },
        "other_compensation_description": {
          "title": "other_compensation_description.title",
          "type": "string"
        }
      },
      "required": [
        "other_compensation_issuer",
        "other_compensation_issuer_name",
        "other_compensation_issuer_year",
        "other_compensation_amount",
        "other_compensation_description"
      ]
    },
    "grant_info_step": {
      "required": [
        "acting_year_section",
        "primary_art_field_section",
        "other_compensations_section"
      ],
      "properties": {
        "acting_year_section": {
          "title": "acting_year_section.title",
          "type": "object",
          "properties": {
            "acting_year": {
              "title": "acting_year_section_acting_year.title",
              "type": "string"
            }
          },
          "required": ["acting_year"]
        },
        "subventions_section": {
          "title": "subventions_section.title",
          "type": "object",
          "properties": {
            "subventions": {
              "title": "subventions.title",
              "options": [
                {
                  "id": 1,
                  "label": "subventions.1.title"
                }
              ]
            }
          }
        },
        "subventions_total": {
          "type": "number"
        },
        "multi_year_grant_section": {
          "type": "object",
          "default": {}
        },
        "primary_art_field_section": {
          "type": "object",
          "properties": {
            "primary_art_field": {
              "title": "primary_art_field.title",
              "type": "string",
              "enum": [
                "primary_art_field.design_and_crafts",
                "primary_art_field.film_photography_and_media",
                "primary_art_field.urban_culture",
                "primary_art_field.literature",
                "primary_art_field.visual_arts_and_comics",
                "primary_art_field.multidisciplinary_art",
                "primary_art_field.museum",
                "primary_art_field.music",
                "primary_art_field.other",
                "primary_art_field.circus",
                "primary_art_field.dance",
                "primary_art_field.theatre"
              ]
            },
            "is_festival_or_event": {
              "title": "is_festival_or_event.title",
              "description": "is_festival_or_event.description",
              "enum": [
                true,
                false
              ]
            },
            "project_brief_description": {
              "title": "project_brief_description.title",
              "type": "string",
              "maxLength": 700
            }
          },
          "required": [
            "primary_art_field",
            "is_festival_or_event",
            "project_brief_description"
          ]
        },
        "other_compensations_section": {
          "title": "other_compensations_section.title",
          "description": "other_compensations_section.description",
          "type": "object",
          "properties": {
            "have_received_other_compensations": {
              "title": "other_compensations_section_have_received_other_compensations.title",
              "enum": [
                false,
                true
              ],
              "default": false
            }
          },
          "required": ["have_received_other_compensations"],
          "allOf": [
            {
              "if": {
                "properties": {
                  "have_received_other_compensations": {
                    "const": true
                  }
                }
              },
              "then": {
                "properties": {
                  "other_compensations": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/_other_compensation_item"
                    },
                    "additionalItems": {
                      "$ref": "#/definitions/_other_compensation_item"
                    },
                    "minItems": 1
                  }
                }
              }
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "subventions_total": {
                "minimum": 5001
              }
            },
            "required": ["subventions_total"]
          },
          "then": {
            "properties": {
              "multi_year_grant_section": {
                "type": "object",
                "properties": {
                  "is_multi_year_grant": {
                    "title": "is_multi_year_grant.title",
                    "description": "is_multi_year_grant.description",
                    "enum": [
                      false,
                      true
                    ],
                    "default": false
                  }
                },
                "required": ["is_multi_year_grant"],
                "allOf": [
                  {
                    "if": {
                      "properties": {
                        "is_multi_year_grant": {
                          "const": true
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "future_years_for_multi_year_grant": {
                          "title": "future_years_for_multi_year_grant.title",
                          "type": "string",
                          "maxLength": 100
                        },
                        "grant_amount_breakdown_per_year": {
                          "title": "grant_amount_breakdown_per_year.title",
                          "type": "string",
                          "maxLength": 100
                        }
                      },
                      "required": [
                        "future_years_for_multi_year_grant",
                        "grant_amount_breakdown_per_year"
                      ]
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    }
  },
  "description": "",
  "title": "form_title",
  "type": "object",
  "properties": {
    "grant_info_step": {
      "title": "grant_info_step.title",
      "type": "object",
      "$ref": "#/definitions/grant_info_step"
    }
  }
}
