{
  "grant_info_step": {
    "acting_year_section": {
      "acting_year": {
        "ui:field": "actingYear"
      }
    },
    "subventions_section": {
      "subventions": {
        "ui:field": "subventionTable"
      }
    },
    "subventions_total": {
      "ui:field": "computedSum",
      "misc:exclude-from-submit": true,
      "ui:options": {
        "sourceFields": ["grant_info_step.subventions_section.subventions"],
        "sourceShape": "subvention",
        "numericOutput": true,
        "hidden": true
      }
    },
    "multi_year_grant_section": {
      "is_multi_year_grant": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        }
      },
      "future_years_for_multi_year_grant": {
        "misc:max-length": 100,
        "ui:options": {
          "tooltipLabel": "future_years_for_multi_year_grant.title",
          "tooltipButtonLabel": "future_years_for_multi_year_grant.title",
          "tooltipText": "future_years_for_multi_year_grant.tooltip"
        }
      },
      "grant_amount_breakdown_per_year": {
        "misc:max-length": 100,
        "ui:options": {
          "tooltipLabel": "grant_amount_breakdown_per_year.title",
          "tooltipButtonLabel": "grant_amount_breakdown_per_year.title",
          "tooltipText": "grant_amount_breakdown_per_year.tooltip"
        }
      }
    },
    "primary_art_field_section": {
      "primary_art_field": {
        "ui:options": {
          "tooltipLabel": "primary_art_field.title",
          "tooltipButtonLabel": "primary_art_field.title",
          "tooltipText": "primary_art_field.tooltip"
        }
      },
      "is_festival_or_event": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "tooltipLabel": "is_festival_or_event.title",
          "tooltipButtonLabel": "is_festival_or_event.title",
          "tooltipText": "is_festival_or_event.tooltip"
        }
      },
      "project_brief_description": {
        "misc:max-length": 700,
        "ui:widget": "textarea",
        "ui:options": {
          "tooltipLabel": "project_brief_description.title",
          "tooltipButtonLabel": "project_brief_description.title",
          "tooltipText": "project_brief_description.tooltip"
        }
      }
    },
    "other_compensations_section": {
      "have_received_other_compensations": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:options": {
          "affirmativeExpands": true
        }
      },
      "other_compensations": {
        "ui:options": {
          "addText": "other_compensation.add"
        },
        "items": {
          "other_compensation_issuer_name": {
            "ui:options": {
              "tooltipLabel": "other_compensation_issuer.title",
              "tooltipButtonLabel": "other_compensation_issuer.title",
              "tooltipText": "other_compensation_issuer.description"
            }
          },
          "other_compensation_amount": {
            "ui:options": {
              "printableName": "other_compensation_amount.printable_title"
            }
          },
          "other_compensation_description": {
            "ui:widget": "textarea",
            "misc:max-length": 1000,
            "ui:options": {
              "tooltipLabel": "other_compensation_description.title",
              "tooltipButtonLabel": "other_compensation_description.title",
              "tooltipText": "other_compensation_description.description"
            }
          }
        }
      }
    }
  },
  "community_activity_step": {
    "community_members_section": {
      "members_fieldset": {
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "members_fieldset.legend",
          "tooltipButtonLabel": "members_fieldset.legend",
          "tooltipText": "members_fieldset.description"
        }
      }
    },
    "personnel_section": {
      "personnel_fieldset": {
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "personnel_fieldset.legend",
          "tooltipButtonLabel": "personnel_fieldset.legend",
          "tooltipText": "personnel_fieldset.description"
        }
      }
    },
    "artistic_spaces_section": {
      "owns_artistic_space": {
        "ui:widget": "radio",
        "ui:enumNames": [
          "boolean.yes",
          "boolean.no"
        ],
        "ui:options": {
          "affirmativeExpands": true,
          "tooltipLabel": "owns_artistic_space.title",
          "tooltipButtonLabel": "owns_artistic_space.title",
          "tooltipText": "owns_artistic_space.description"
        }
      },
      "spaces": {
        "ui:options": {
          "addText": "spaces.add",
          "hideNameFromPrint": true
        },
        "items": {
          "premiseType": {
            "ui:widget": "select"
          },
          "isOthersUse": {
            "ui:widget": "radio",
            "ui:enumNames": [
              "boolean.yes",
              "boolean.no"
            ]
          },
          "isOwnedByApplicant": {
            "ui:widget": "radio",
            "ui:enumNames": [
              "boolean.yes",
              "boolean.no"
            ]
          },
          "isOwnedByCity": {
            "ui:widget": "radio",
            "ui:enumNames": [
              "boolean.yes",
              "boolean.no"
            ]
          }
        }
      }
    }
  }
}
