{
  "grant_info_step": {
    "acting_year_section": {
      "acting_year": {
        "ui:field": "actingYear"
      }
    },
    "subventions_section": {
      "apply_for_start_grant": {
        "ui:enumNames": [
          "boolean.no",
          "boolean.yes"
        ],
        "ui:widget": "radio"
      },
      "subventions": {
        "ui:field": "subventionTable",
        "ui:options": {
          "startGrant": {
            "controlledBy": "grant_info_step.subventions_section.apply_for_start_grant",
            "subventionId": "31",
            "valueWhenTrue": "500"
          },
          "useSingleSubvention": true
        }
      },
      "subventions_help": {
        "ui:field": "textParagraph"
      }
    },
    "purpose_section": {
      "purpose": {
        "ui:widget": "textarea",
        "ui:options": {
          "tooltipLabel": "purpose_section_purpose.title",
          "tooltipButtonLabel": "purpose_section_purpose.title",
          "tooltipText": "purpose.description"
        }
      }
    }
  },
  "attachments_step": {
    "additional_information_section": {
      "additional_information": {
        "ui:widget": "textarea",
        "ui:options": {
          "hideNameFromPrint": true,
          "tooltipLabel": "additional_information.title",
          "tooltipButtonLabel": "additional_information.title",
          "tooltipText": "additional_information.description"
        }
      }
    },
    "attachments_section": {
      "required_attachments_help": {
        "ui:field": "textParagraph"
      },
      "multiple_attachments_help": {
        "ui:field": "textParagraph"
      },
      "cant_view_after_help": {
        "misc:variant": "infobox",
        "ui:field": "textParagraph"
      },
      "further_clarification": {
        "ui:widget": "textarea"
      },
      "other_attachment_fieldset": {
        "other_attachment_fieldset_file": {
          "misc:file-type": 0,
          "misc:variant": "simple",
          "misc:multiple": "true",
          "ui:help": "other_attachment_fieldset_multiple_files.ui_help",
          "ui:field": "atvFile"
        }
      }
    }
  }
}
