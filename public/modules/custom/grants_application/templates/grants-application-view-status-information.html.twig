<h2>{{ 'Application info'|t }}</h2>
<p>{{ 'Summary about your application and processing details.'|t }}</p>
<div class="hdbt-react-form__submission-info">
  <div class="hdbt-react-form__submission-info__row hdbt-react-form__submission-info__row--top">
    <h4>
      {{ application_name }}
    </h4>
    <div class="hdbt-react-form__submission-info__row__supportlinks">
      <a class="hds-button hds-button--supplementary" href="{{ print_application_link }}">
        <span aria-hidden="true" class="hel-icon hel-icon--printer"></span>
        <span class="hds-button__label">{{ "Print application"|t }}</span>
      </a>
    </div>
  </div>
  <div class="hdbt-react-form__submission-info__row hdbt-react-form__submission-info__row--main">
    <div>
      <h5>{{ "Application number"|t }}</h5>
      {{ submission_id }}
      <h5>{{ 'Sent date'|t }}</h5>
      {{ application_submit_date }}
      <h5>{{ 'Handler information'|t }}</h5>
      {% if not last_handler %}
        <em>{{ "No handler information set"|t }}</em>
      {% else %}
        {% for string in last_handler %}
          <div>
            {{ string }}
          </div>
        {% endfor %}
      {% endif %}
    </div>
    <div>
      <h5>{{ "Application statuses"|t }}</h5>
      <ul className='application-status-history'>
        {% for event in history %}
          <li>{{ event }}</li>
        {% endfor %}
      </ul>
    </div>
    <div>
      <h5>{{ "Application attachments"|t }}</h5>
      <ul className='application-attachment-list'>
        {% for attachment in attachments %}
          <li>{{ attachment }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
  {% if is_editable %}
    <div class="hdbt-react-form__submission-info__row hdbt-react-form__submission-info__row--edit">
      {% include '@hdbt/navigation/link-button.html.twig' with {
        type: 'primary',
        label: 'Edit application'|t,
        url: editApplicationLink,
      }
      %}
    </div>
  {% endif %}
</div>
