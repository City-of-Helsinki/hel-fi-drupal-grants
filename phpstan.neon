includes:
	- phpstan-baseline.neon
parameters:
  fileExtensions:
      - php
      - module
      - install
      - theme
  paths:
    - ./public/modules/custom
    - ./public/themes/custom
  excludePaths:
    - vendor
    - ./public/themes/custom/hdbt_subtheme/node_modules
  level: 7
  treatPhpDocTypesAsCertain: false
  scanFiles:
    - ./public/core/themes/engines/twig/twig.engine
